EXPO_PUBLIC_USE_MOCK_LLM=false
EXPO_PUBLIC_CLAUDE_PROXY_URL=
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_E2E_AUTH_BYPASS=false # test-only
EXPO_PUBLIC_ELEVENLABS_VOICE_ID_GENERIC=cgSgspJ2msm6clMCkdW9
EXPO_PUBLIC_ELEVENLABS_VOICE_ID_CATHY=
# Stripe checkout URLs:
EXPO_PUBLIC_STRIPE_CHECKOUT_URL= # legacy fallback
EXPO_PUBLIC_STRIPE_CHECKOUT_URL_REGULAR=
EXPO_PUBLIC_STRIPE_CHECKOUT_URL_PREMIUM=
# Optional test/sandbox override for mobile/web builds:
# EXPO_PUBLIC_STRIPE_MODE=test
# EXPO_PUBLIC_STRIPE_CHECKOUT_URL_TEST=
# EXPO_PUBLIC_STRIPE_CHECKOUT_URL_REGULAR_TEST=
# EXPO_PUBLIC_STRIPE_CHECKOUT_URL_PREMIUM_TEST=
EXPO_PUBLIC_PAYPAL_CHECKOUT_URL=
EXPO_PUBLIC_APPLE_PAY_CHECKOUT_URL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Backend-only env var (set in Vercel project, not in Expo app env):
# ALLOWED_ORIGINS=https://app.ha-ha.ai,http://localhost:19006,http://localhost:8081,http://localhost:*,http://127.0.0.1:*
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_WEBHOOK_SECRET_TEST=
# STRIPE_SECRET_KEY=
# STRIPE_SECRET_KEY_TEST=
# STRIPE_PAYMENT_LINK_ID_REGULAR=
# STRIPE_PAYMENT_LINK_ID_PREMIUM=
# STRIPE_PAYMENT_LINK_ID_REGULAR_TEST=
# STRIPE_PAYMENT_LINK_ID_PREMIUM_TEST=
# STRIPE_PRICE_ID_REGULAR_MONTHLY=
# STRIPE_PRICE_ID_PREMIUM_MONTHLY=
# STRIPE_PRICE_ID_REGULAR_ANNUAL=
# STRIPE_PRICE_ID_PREMIUM_ANNUAL=
# STRIPE_PRICE_ID_REGULAR_MONTHLY_TEST=
# STRIPE_PRICE_ID_PREMIUM_MONTHLY_TEST=
# STRIPE_PRICE_ID_REGULAR_ANNUAL_TEST=
# STRIPE_PRICE_ID_PREMIUM_ANNUAL_TEST=
# ENABLE_ADMIN_TIER_GRANTS=false  # keep false in prod unless explicit admin-tier promotion is required
# CLAUDE_RATE_LIMIT_MAX_REQUESTS=30
# CLAUDE_RATE_LIMIT_WINDOW_MS=60000
# Monthly message caps per account tier (optional overrides)
# CLAUDE_MONTHLY_CAP_FREE=40
# CLAUDE_MONTHLY_CAP_REGULAR=300
# CLAUDE_MONTHLY_CAP_PREMIUM=600
# CLAUDE_LIMITS_RPC=true # optional: enable single-RPC quota/rate-limit tracking after running docs/supabase-account-types.sql
# ANTHROPIC_FETCH_TIMEOUT_MS=25000
# ELEVENLABS_VOICE_ID_GENERIC=  # server-side override for regular/generic voice
# ELEVENLABS_VOICE_ID_CATHY=    # server-side Cathy voice id (recommended)
# ELEVENLABS_USE_CATHY_FOR_ALL_PAID=true
# ELEVENLABS_MODEL_ID=eleven_v3
# accepted aliases: eleven_v3 | v3 | 3 | eleven_turbo_v2_5 | v2.5 | 2.5
# v3 "closer to v2.5 timbre" tuning preset:
# ELEVENLABS_STABILITY=0.72
# ELEVENLABS_SIMILARITY_BOOST=0.92
# ELEVENLABS_STYLE=0.08
# ELEVENLABS_FETCH_TIMEOUT_MS=20000
# TTS_RATE_LIMIT_MAX_REQUESTS=20
# TTS_RATE_LIMIT_WINDOW_MS=60000
# TTS_MONTHLY_CAP_REGULAR=200
# TTS_MONTHLY_CAP_PREMIUM=500
# SENTRY_DSN=
# SENTRY_DSN_API= # optional API-specific override; falls back to SENTRY_DSN
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SUPABASE_JWT_SECRET=  # Optional if validating JWT manually; kept for reference.
