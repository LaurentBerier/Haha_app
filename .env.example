EXPO_PUBLIC_USE_MOCK_LLM=false
EXPO_PUBLIC_CLAUDE_PROXY_URL=
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_E2E_AUTH_BYPASS=false # test-only
# Stripe checkout URLs:
EXPO_PUBLIC_STRIPE_CHECKOUT_URL= # legacy fallback
EXPO_PUBLIC_STRIPE_CHECKOUT_URL_REGULAR=
EXPO_PUBLIC_STRIPE_CHECKOUT_URL_PREMIUM=
EXPO_PUBLIC_PAYPAL_CHECKOUT_URL=
EXPO_PUBLIC_APPLE_PAY_CHECKOUT_URL=

# Backend-only env var (set in Vercel project, not in Expo app env):
# ANTHROPIC_API_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_PAYMENT_LINK_ID_REGULAR=
# STRIPE_PAYMENT_LINK_ID_PREMIUM=
# STRIPE_PRICE_ID_REGULAR_MONTHLY=
# STRIPE_PRICE_ID_PREMIUM_MONTHLY=
# STRIPE_PRICE_ID_REGULAR_ANNUAL=
# STRIPE_PRICE_ID_PREMIUM_ANNUAL=
# ENABLE_ADMIN_TIER_GRANTS=false  # keep false in prod unless explicit admin-tier promotion is required
# CLAUDE_RATE_LIMIT_MAX_REQUESTS=30
# CLAUDE_RATE_LIMIT_WINDOW_MS=60000
# Monthly message caps per account tier (optional overrides)
# CLAUDE_MONTHLY_CAP_FREE=15
# CLAUDE_MONTHLY_CAP_REGULAR=45
# CLAUDE_MONTHLY_CAP_PREMIUM=110
# ANTHROPIC_FETCH_TIMEOUT_MS=25000
# SUPABASE_JWT_SECRET=  # Optional if validating JWT manually; kept for reference.
