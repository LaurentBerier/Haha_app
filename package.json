{
  "name": "ha-ha-ai",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "node scripts/exportWeb.mjs",
    "deploy:web": "node scripts/verifyVercelProject.mjs && npm run export:web && npx vercel --prod --yes --scope snadeau-breakingwalls-projects --archive=tgz",
    "vercel:link:app": "npx vercel link --project haha-app --scope snadeau-breakingwalls-projects --yes",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test:unit": "jest --config jest.unit.config.cjs --runInBand",
    "smoke:auth": "./scripts/smoke-auth.sh",
    "smoke:voice": "./scripts/smoke-voice.sh",
    "qa:phase23": "./scripts/qa-phase23.sh",
    "verify:profile-prompt": "tsx scripts/verifyProfilePrompt.ts",
    "e2e:build:ios": "EXPO_PUBLIC_E2E_AUTH_BYPASS=true EXPO_PUBLIC_USE_MOCK_LLM=true detox build -c ios.sim.debug",
    "e2e:ios": "EXPO_PUBLIC_E2E_AUTH_BYPASS=true EXPO_PUBLIC_USE_MOCK_LLM=true detox test -c ios.sim.debug --cleanup",
    "import:modes": "tsx scripts/importModes.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~53.0.0",
    "expo-apple-authentication": "~7.2.4",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.7",
    "expo-file-system": "~18.1.11",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.1",
    "expo-speech-recognition": "^3.1.1",
    "expo-status-bar": "~2.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "stripe": "^20.4.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.39.1",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.0.10",
    "@types/react-native": "0.73.0",
    "detox": "^20.47.0",
    "eslint": "^9.17.0",
    "globals": "^15.15.0",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.0",
    "xlsx": "^0.18.5"
  }
}
