{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run export:web",
  "outputDirectory": "dist-web",
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    },
    "api/admin-account-type.js": {
      "maxDuration": 60
    },
    "api/game-judge.js": {
      "maxDuration": 60
    },
    "api/game-questions.js": {
      "maxDuration": 60
    },
    "api/stripe-webhook.js": {
      "maxDuration": 60
    },
    "api/admin-stats.js": {
      "maxDuration": 30
    },
    "api/admin-users.js": {
      "maxDuration": 30
    },
    "api/admin-quota-override.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/tts",
      "dest": "/api/claude?__proxy=tts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
