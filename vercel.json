{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run export:web",
  "outputDirectory": "dist-web",
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    },
    "api/admin-account-type.js": {
      "maxDuration": 60
    },
    "api/game-judge.js": {
      "maxDuration": 60
    },
    "api/game-questions.js": {
      "maxDuration": 60
    },
    "api/stripe-webhook.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
